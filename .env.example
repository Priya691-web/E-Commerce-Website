# ============================================================
# ENVIRONMENT VARIABLES - FashionStore
# Copy this file to .env and configure for your environment
# DO NOT commit .env file to version control
# ============================================================

# Application Environment
ENVIRONMENT=development
APP_NAME=fashionstore
APP_VERSION=1.0.0
FASHIONSTORE_PROFILE=development

# ============================================================
# DATABASE CONFIGURATION (CRITICAL FOR PRODUCTION)
# ============================================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fashionstore
DB_USER=root
DB_PASSWORD=change_this_password_in_production
MYSQL_ROOT_PASSWORD=change_this_password_in_production

# Production Database URL (if using external database)
# Format: jdbc:mysql://host:port/dbname?useSSL=true&serverTimezone=UTC
FASHIONSTORE_DB_URL=jdbc:mysql://localhost:3306/fashionstore?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
FASHIONSTORE_DB_USER=root
FASHIONSTORE_DB_PASSWORD=change_this_password_in_production

# ============================================================
# REDIS CONFIGURATION
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

FASHIONSTORE_REDIS_HOST=redis
FASHIONSTORE_REDIS_PORT=6379
FASHIONSTORE_REDIS_PASSWORD=

# ============================================================
# JWT CONFIGURATION (CRITICAL - MUST BE SET IN PRODUCTION)
# ============================================================
# JWT secret key - MUST be at least 64 characters in production
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=generate_a_strong_64_char_secret_here_minimum_64_characters_required_for_production

# Admin registration key - protects admin account creation
FASHIONSTORE_ADMIN_KEY=change_this_admin_key_in_production

# ============================================================
# STRIPE PAYMENT CONFIGURATION
# ============================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================
# SERVER CONFIGURATION
# ============================================================
SERVER_PORT=8080
ADMIN_PORT=8081
NGINX_PORT=80
NGINX_SSL_PORT=443

# ============================================================
# SECURITY CONFIGURATION (CRITICAL - SET THESE IN PRODUCTION)
# ============================================================
HTTPS_ENABLED=false
SECURE_COOKIES=false
RATE_LIMIT_ENABLED=false
CSRF_ENABLED=false
QA_MODE=true
DEMO_MODE=true
DEMO_HARDENING_MODE=true

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8081

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=TEXT

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
VITE_API_BASE=http://localhost:8080

# ============================================================
# DOCKER CONFIGURATION
# ============================================================
COMPOSE_PROJECT_NAME=fashionstore

# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# When deploying to production, override the above with:
# ENVIRONMENT=production
# FASHIONSTORE_PROFILE=production
# JWT_SECRET_KEY=<your-64-char-secret>
# HTTPS_ENABLED=true
# SECURE_COOKIES=true
# RATE_LIMIT_ENABLED=true
# CSRF_ENABLED=true
# QA_MODE=false
# DEMO_MODE=false
# DEMO_HARDENING_MODE=false
# LOG_LEVEL=INFO

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. NEVER commit .env file to version control
# 2. Use strong, unique passwords for all environments
# 3. JWT_SECRET_KEY must be at least 64 characters in production
# 4. Enable HTTPS_ENABLED and SECURE_COOKIES in production
# 5. Enable RATE_LIMIT_ENABLED in production
# 6. Enable DB_SSL in production database URL
# 7. Rotate secrets regularly
# 8. Use different credentials for each environment
# 9. Never use default passwords in production
# 10. Restrict database access to application servers only
