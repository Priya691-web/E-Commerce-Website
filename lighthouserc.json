{
  "ci": {
    "collect": {
      "staticDistDir": "./frontend/admin/dist",
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["accessibility", "performance", "best-practices", "seo"],
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
